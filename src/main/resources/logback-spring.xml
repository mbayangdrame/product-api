<configuration>

    <!-- CONSOLE -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss} %-5level [%thread] %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- LOKI ACTIVÉ SEULEMENT SI VARIABLE EXISTE -->
    <if condition='isDefined("LOKI_URL")'>
        <then>
            <appender name="LOKI" class="com.github.loki4j.logback.Loki4jAppender">
                <http>
                    <url>http://${LOKI_URL}:3100/loki/api/v1/push</url>
                </http>
                <format>
                    <label>
                        <pattern>app=${spring.application.name},env=kubernetes</pattern>
                    </label>
                    <message>
                        <pattern>%-5level [%thread] %logger{36} - %msg%n</pattern>
                    </message>
                </format>
            </appender>

            <root level="INFO">
                <appender-ref ref="CONSOLE"/>
                <appender-ref ref="LOKI"/>
            </root>
        </then>

        <else>
            <root level="INFO">
                <appender-ref ref="CONSOLE"/>
            </root>
        </else>
    </if>

</configuration>